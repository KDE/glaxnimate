msgstr "Přejde na předchozí snímek."

#: src/android/help_dialog.cpp:190
#, kde-format
msgid "Goes to the next frame."
msgstr "Přejde na další snímek."

#: src/android/help_dialog.cpp:194
#, kde-format
msgid "Jumps to the last frame."
msgstr "Přejde na poslední snímek."

#: src/android/help_dialog.cpp:198
#, kde-format
msgid ""
"When enabled (which is the default) whenever you change an object property, "
"a new keyframe is added for that property."
msgstr ""
"Je-li tato funkce zapnutá (což je výchozí nastavení), při každé změně "
"vlastnosti objektu se pro danou vlastnost přidá nový klíčový snímek."

#: src/android/help_dialog.cpp:202
#, kde-format
msgid "Push the selection further back."
msgstr "Posune výběr ještě více dozadu."

#: src/android/help_dialog.cpp:206
#, kde-format
msgid "Brings the selection further to the front."
msgstr "Posune výběr ještě více dopředu."

