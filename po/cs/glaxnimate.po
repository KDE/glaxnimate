#: src/android/help_dialog.cpp:54
#, kde-format
msgid "Clears the current document and creates a new empty one"
msgstr "Vymaže aktuální dokument a vytvoří nový prázdný dokument"

#: src/android/help_dialog.cpp:58
#, kde-format
msgid ""
"Prompts the user to select a document to open.\n"
"Currently the following formats are supported:\n"
"%1"
msgstr ""
"Vyzve uživatele k výběru dokumentu, který se má otevřít.\n"
"V současné době jsou podporovány následující formáty:\n"
"%1"

#: src/android/help_dialog.cpp:62
#, kde-format
msgid ""
"Prompts the user to select a document to append as an object to the current "
"one."
msgstr ""
"Vyzve uživatele, aby vybral dokument, který se má připojit jako objekt k "
"aktuálnímu dokumentu."

#: src/android/help_dialog.cpp:66
#, kde-format
msgid "Save the current document, prompting to select a file for new documents"
msgstr ""
"Uložit aktuální dokument; při vytváření nových dokumentů se zobrazí výzva k "
"výběru souboru"

#: src/android/help_dialog.cpp:70
#, kde-format
msgid "Save the current document, always prompting to select a file."
msgstr "Uložit aktuální dokument a vždy zobrazit výzvu k výběru souboru."

#: src/android/help_dialog.cpp:74
#, kde-format
msgid ""
"Save a copy of current document, prompting to select a format and a file.\n"
"Currently the following formats are supported:\n"
"%1"
msgstr ""
"Uložit kopii aktuálního dokumentu s výzvou k výběru formátu a souboru.\n"
"V současné době jsou podporovány následující formáty:\n"
"%1"

#: src/android/help_dialog.cpp:78
#, kde-format
msgid "Saves the current frame as a still image"
msgstr "Uloží aktuální snímek jako statický obrázek"

#: src/android/help_dialog.cpp:82
#, kde-format
msgid ""
"Creates a sticker pack to export to Telegram.\n"
"Note that only recent version of Telegram support this.\n"
"If your Telegram version is too old, you can Export the file to TGS and "
"upload that on Telegram."
msgstr ""
"Vytvoří balíček samolepek k exportu do aplikace Telegram.\n"
"Upozorňujeme, že tuto funkci podporují pouze nejnovější verze aplikace "
"Telegram.\n"
"Pokud máte příliš starou verzi aplikace Telegram, můžete soubor exportovat "
"do formátu TGS a ten pak nahrát do aplikace Telegram."

#: src/android/help_dialog.cpp:86
#, kde-format
msgid "Cuts the selection into the clipboard."
msgstr "Vyjme výběr a vloží jej do schránky."

#: src/android/help_dialog.cpp:90
#, kde-format
msgid "Copies the selection into the clipboard."
msgstr "Zkopíruje výběr do schránky."

#: src/android/help_dialog.cpp:94
#, kde-format
msgid "Pastes from the clipboard into the current document."
msgstr "Vloží obsah schránky do aktuálního dokumentu."

#: src/android/help_dialog.cpp:98
#, kde-format
msgid "Removes the selected item."
msgstr "Odstraní vybranou položku."

#: src/android/help_dialog.cpp:102
#, kde-format
msgid "Undoes the last action."
msgstr "Zruší poslední akci."

#: src/android/help_dialog.cpp:106
#, kde-format
msgid "Redoes the last undone action."
msgstr "Zopakuje poslední zrušenou akci."

#: src/android/help_dialog.cpp:110
#, kde-format
msgid ""
"Opens the side pane used to change the advanced properties for the selected "
"object."
msgstr ""
"Otevře boční panel, který slouží ke změně pokročilých vlastností vybraného "
"objektu."

#: src/android/help_dialog.cpp:114
#, kde-format
msgid "Shows the timeline and playback controls."
msgstr "Zobrazí časovou osu a ovládací prvky přehrávání."

#: src/android/help_dialog.cpp:118
#, kde-format
msgid "Opens the side pane used to select the fill color."
msgstr "Otevře boční panel, který slouží k výběru barvy výplně."

#: src/android/help_dialog.cpp:122
#, kde-format
msgid "Opens the side pane used to select the stroke color and style."
msgstr "Otevře boční panel, který slouží k výběru barvy a stylu obrysu."

#: src/android/help_dialog.cpp:126
#, kde-format
msgid "Shows this help."
msgstr "Zobrazí tuto nápovědu."

#: src/android/help_dialog.cpp:130
#, kde-format
msgid ""
"Select tool, you can use it to select objects and change their transform."
msgstr ""
"Nástroj pro výběr. Můžete jej použít k výběru objektů a změně jejich "
"transformace."

#: src/android/help_dialog.cpp:134
#, kde-format
msgid ""
"Edit tool, used to edit existing items (eg: moving, bezier nodes, setting "
"rounded corners on a rectangle, etc.)"
msgstr ""
"Nástroj pro úpravy, který slouží k úpravám stávajících prvků (např. "
"přesouvání, úpravy Bézierových uzlů, nastavení zaoblených rohů obdélníku "
"atd.)"

#: src/android/help_dialog.cpp:138
#, kde-format
msgid "Shows a tray with the curve drawing tools."
msgstr "Zobrazí panel s nástroji pro kreslení křivek."

#: src/android/help_dialog.cpp:142
#, kde-format
msgid "Create Bezier curves using nodes and handles."
msgstr "Vytvoří Bézierovy křivky pomocí uzlů a úchytů."

#: src/android/help_dialog.cpp:146
#, kde-format
msgid "Draw curves freehand."
msgstr "Kreslení křivek volnou rukou."

#: src/android/help_dialog.cpp:150
#, kde-format
msgid "Shows a tray with the shape drawing tools."
msgstr "Zobrazí panel s nástroji pro kreslení tvarů."

#: src/android/help_dialog.cpp:154
#, kde-format
msgid "Draws rectangles."
msgstr "Kreslí obdélníky."

#: src/android/help_dialog.cpp:158
#, kde-format
msgid "Draws ellipses."
msgstr "Kreslí elipsy."

#: src/android/help_dialog.cpp:162
#, kde-format
msgid ""
"Draws a star, after it's been created you can change it into a regular "
"polygon and change the number of sides from the properties pane."
msgstr ""
"Nakreslí hvězdu; po jejím vytvoření ji můžete v panelu vlastností změnit na "
"pravidelný mnohoúhelník a upravit počet stran."

#: src/android/help_dialog.cpp:166
#, kde-format
msgid "Create and edit text shapes."
msgstr "Vytváření a úprava textových tvarů."

#: src/android/help_dialog.cpp:170
#, kde-format
msgid "Toggles the menu showing non-drawing buttons."
msgstr "Zapíná/vypíná zobrazení tlačítek v nabídce, která neslouží k kreslení."

#: src/android/help_dialog.cpp:174
#, kde-format
msgid "Starts playback."
msgstr "Spustí přehrávání."

#: src/android/help_dialog.cpp:178
#, kde-format
msgid "Toggles looping for the playback (on by default)."
msgstr "Zapíná/vypíná opakované přehrávání (ve výchozím nastavení zapnuto)."

#: src/android/help_dialog.cpp:182
#, kde-format
msgid "Jumps to the first frame."
msgstr "Přejde na první snímek."

#: src/android/help_dialog.cpp:186
#, kde-format
